{
  "rules": {
    "players_s1": {
      ".read": true,
      "$playerId": {
        ".read": true,
        ".write": true
      }
    },
    "players_s2": {
      ".read": true,
      "$playerId": {
        ".read": true,
        ".write": true
      }
    },
    "players_s3": {
      ".read": true,
      "$playerId": {
        ".read": true,
        ".write": true
      }
    },
    "players_s4": {
      ".read": true,
      "$playerId": {
        ".read": true,
        ".write": true
      }
    },
    "players_s5": {
      ".read": true,
      "$playerId": {
        ".read": true,
        ".write": true
      }
    },
    "referrals_v1": {
      ".read": true,
      ".write": true,
      "$season": {
        ".read": true,
        ".write": true,
        "summary": {
          ".indexOn": ["pendingReward", "earnedTotal", "lastRewardAt"]
        },
        "reward_events": {
          ".indexOn": ["ts", "kind", "spenderId"]
        },
        "claim_history": {
          "$userId": {
            ".indexOn": ["ts"]
          }
        }
      }
    }
  }
}
