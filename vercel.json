{
  "functions": {
    "api/nft-image.js": {
      "includeFiles": "PTG-main.png"
    }
  },
  "headers": [
    {
      "source": "/api/nft-image",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Cache-Control", "value": "public, max-age=604800, s-maxage=86400" }
      ]
    },
    {
      "source": "/nft.json",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Cache-Control", "value": "public, max-age=60, s-maxage=300" }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/.well-known/farcaster.json",
      "destination": "https://api.farcaster.xyz/miniapps/hosted-manifest/019bb823-972c-a411-2159-1f26c93aa3d4",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/api/mint-voucher",
      "destination": "/api/ptg-voucher"
    }
  ]
}